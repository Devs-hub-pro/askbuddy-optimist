<view class="container safe-bottom">
  <view class="title">发现</view>
  <view class="subtitle">热点话题与内容推荐（Mock 版）</view>

  <state-card wx:if="{{loading}}" title="加载中" desc="正在获取发现内容" />
  <state-card wx:elif="{{error}}" title="加载失败" desc="{{error}}" actionText="重试" bind:action="loadData" />

  <view wx:else>
    <view wx:for="{{list}}" wx:key="id" class="card" style="margin-top: 20rpx;">
      <view class="row">
        <view class="title" style="font-size: 30rpx;">{{item.title}}</view>
        <text wx:if="{{item.hot}}" style="color: #ef4444; font-size: 24rpx;">HOT</text>
      </view>
      <view class="subtitle" style="margin-top: 8rpx;">{{item.participants}} 人参与</view>
    </view>
  </view>
</view>
