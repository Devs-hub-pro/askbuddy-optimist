<view class="container safe-bottom">
  <view class="row">
    <view>
      <view class="title">首页</view>
      <view class="subtitle">先用 Mock 跑通主链路，再切真实接口</view>
    </view>
    <button class="button-primary" size="mini" bindtap="goAsk">去提问</button>
  </view>

  <state-card wx:if="{{loading}}" title="加载中" desc="正在拉取首页内容" />
  <state-card wx:elif="{{error}}" title="加载失败" desc="{{error}}" actionText="重试" bind:action="loadData" />

  <view wx:else>
    <view wx:for="{{list}}" wx:key="id" class="card" style="margin-top: 20rpx;" bindtap="goDetail" data-id="{{item.id}}">
      <view class="title" style="font-size: 32rpx;">{{item.title}}</view>
      <view class="subtitle" style="margin-top: 10rpx;">{{item.content}}</view>
      <view class="row" style="margin-top: 14rpx;">
        <text class="subtitle">{{item.authorName}} · {{item.createdAt}}</text>
        <text class="subtitle">{{item.answerCount}} 回答</text>
      </view>
    </view>
  </view>
</view>
