<view class="container safe-bottom">
  <view class="title">消息</view>
  <view class="subtitle">会话列表（联调前使用 Mock）</view>

  <state-card wx:if="{{loading}}" title="加载中" desc="正在拉取会话" />
  <state-card wx:elif="{{error}}" title="加载失败" desc="{{error}}" actionText="重试" bind:action="loadData" />

  <view wx:else>
    <view wx:for="{{list}}" wx:key="id" class="card" style="margin-top: 20rpx;">
      <view class="row">
        <view class="title" style="font-size: 30rpx;">{{item.peerName}}</view>
        <text class="subtitle">{{item.updatedAt}}</text>
      </view>
      <view class="row" style="margin-top: 8rpx;">
        <text class="subtitle">{{item.lastMessage}}</text>
        <text wx:if="{{item.unread > 0}}" style="font-size:24rpx;color:#ef4444;">{{item.unread}}</text>
      </view>
    </view>
  </view>
</view>
